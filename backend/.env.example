# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Database (PostgreSQL) ───────────────────────────────
# Local dev via docker-compose: postgresql://dhopabari:dhopabari@localhost:5432/dhopabari
DATABASE_URL="postgresql://dhopabari:dhopabari@localhost:5432/dhopabari"

# ── App JWT (issued by our API after Firebase/password verification) ──
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ── Admin bootstrap (used only by prisma/seed.js to create the first admin) ──
ADMIN_SEED_PHONE="01700000000"
ADMIN_SEED_PASSWORD="admin2026"

# ── Firebase Authentication (Google Sign-In only) + Cloud Messaging ────
# Get these from Firebase Console > Project Settings > Service Accounts
# (generate a new private key, then copy the 3 fields below).
# Leave blank to run in "dev mode": Google Sign-In accepts a demo token
# ("DEMO_TOKEN:<phone>") instead of verifying real Firebase ID tokens.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Email (password reset for Mobile Number + Password accounts) ───────
# No SMS/phone OTP is used anywhere in this app. Leave blank to run in
# "dev mode": the reset link is logged to the server console and returned
# in the API response instead of being emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL="no-reply@dhopabari.com"
SMTP_FROM_NAME="Dhopa Bari"
RESET_PASSWORD_WEB_URL="http://localhost:3000/reset-password"
RESET_PASSWORD_TTL_MINUTES=30

# ── Cloudinary (image uploads) ──────────────────────────
# Leave blank to disable uploads (endpoints will return 503).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google Maps (geocoding, distance, static maps) ──────
GOOGLE_MAPS_API_KEY=

# ── Payment gateways ─────────────────────────────────────
# Leave blank to disable that method (Cash on Delivery always works).
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL="https://tokenized.sandbox.bka.sh/v1.2.0-beta"

NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=
NAGAD_PG_PUBLIC_KEY=
NAGAD_BASE_URL="https://sandbox.mynagad.com/remote-payment-gateway-1.0"

SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true
