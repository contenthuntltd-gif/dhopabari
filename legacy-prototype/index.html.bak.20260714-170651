<!doctype html>
<html lang="bn">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ধোপা বাড়ি Prototype</title>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Noto+Serif+Bengali:wght@400;500;600;700;800;900&display=swap");

    :root {
      --blue: #0874f8;
      --blue-dark: #071939;
      --cyan: #10c9b2;
      --green: #13c49a;
      --red: #f43f5e;
      --ink: #091632;
      --muted: #727b8e;
      --line: #e7ebf2;
      --soft: #f5f8fc;
      --card: #ffffff;
      --shadow: 0 12px 30px rgba(9, 22, 50, .09);
      --app-font: "Noto Serif Bengali", "SolaimanLipi", "Siyam Rupali", "Noto Sans Bengali", "Hind Siliguri", "Segoe UI", Arial, sans-serif;
      font-family: var(--app-font);
    }

    * { box-sizing: border-box; }
    html, body, button, input, textarea { font-family: var(--app-font); }
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: radial-gradient(circle at 20% 10%, #e6f4ff, transparent 28%),
                  radial-gradient(circle at 80% 85%, #dffbf4, transparent 30%),
                  #eef3f8;
      color: var(--ink);
    }

    button, input, textarea { font: inherit; }
    button { cursor: pointer; border: 0; color: inherit; background: transparent; }

    .phone {
      width: min(420px, 100vw);
      height: min(900px, 100vh);
      background: #fff;
      border: 0;
      border-radius: 0;
      overflow: hidden;
      position: relative;
      box-shadow: none;
    }

    .island {
      display: none;
    }

    .status {
      display: none;
      height: 0;
      padding: 0;
      justify-content: space-between;
      align-items: flex-start;
      font-weight: 800;
      font-size: 14px;
      position: relative;
      z-index: 10;
      pointer-events: none;
    }

    .status.light { color: #fff; }
    .signals { display: flex; align-items: center; gap: 7px; }
    .bars { display: flex; align-items: flex-end; gap: 2px; height: 13px; }
    .bars span { width: 3px; background: currentColor; border-radius: 4px; }
    .bars span:nth-child(1) { height: 5px; }
    .bars span:nth-child(2) { height: 8px; }
    .bars span:nth-child(3) { height: 11px; }
    .bars span:nth-child(4) { height: 13px; }
    .wifi {
      width: 16px;
      height: 12px;
      border: 3px solid currentColor;
      border-left-color: transparent;
      border-right-color: transparent;
      border-bottom: 0;
      border-radius: 16px 16px 0 0;
      position: relative;
    }
    .wifi:after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -6px;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: currentColor;
      transform: translateX(-50%);
    }
    .battery {
      width: 23px;
      height: 11px;
      border: 2px solid currentColor;
      border-radius: 3px;
      position: relative;
    }
    .battery:before { content: ""; position: absolute; right: -5px; top: 2px; width: 3px; height: 5px; background: currentColor; border-radius: 0 2px 2px 0; }
    .battery:after { content: ""; position: absolute; left: 2px; top: 2px; width: 15px; height: 5px; background: currentColor; border-radius: 1px; }

    .screen {
      position: absolute;
      inset: 0;
      display: none;
      background: #fff;
      overflow: hidden;
    }
    .screen.active { display: block; }
    .content {
      height: 100%;
      overflow: auto;
      padding: 22px 22px 96px;
      scrollbar-width: none;
    }
    .content::-webkit-scrollbar { width: 0; height: 0; }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 46px;
      gap: 12px;
    }
    .brand { color: var(--blue); font-weight: 900; font-size: 27px; }
    h1, h2, h3, p { margin: 0; }
    .title { font-size: 29px; font-weight: 900; line-height: 1.25; letter-spacing: 0; }
    .subtitle { color: var(--muted); font-size: 15px; line-height: 1.6; }
    .back, .icon-btn {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: var(--ink);
      font-size: 28px;
    }
    .icon { width: 26px; height: 26px; display: inline-block; vertical-align: middle; }
    .bell { position: relative; }
    .badge {
      position: absolute;
      top: 0;
      right: 0;
      min-width: 18px;
      height: 18px;
      padding: 0 4px;
      border-radius: 999px;
      background: var(--red);
      color: #fff;
      font-size: 12px;
      display: grid;
      place-items: center;
      border: 2px solid #fff;
      font-weight: 900;
    }

    .primary {
      min-height: 56px;
      border-radius: 8px;
      background: var(--blue);
      color: #fff;
      font-weight: 900;
      font-size: 20px;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      box-shadow: 0 10px 20px rgba(8, 116, 248, .2);
    }
    .primary.green { background: var(--green); box-shadow: 0 10px 24px rgba(19, 196, 154, .22); }
    .outline {
      min-height: 54px;
      border: 1.5px solid var(--blue);
      color: var(--blue);
      border-radius: 8px;
      font-weight: 900;
      font-size: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
    }

    .splash {
      background: linear-gradient(180deg, #0874f8 0%, #07c8b6 100%);
      color: #fff;
      display: none;
    }
    .splash.active { display: grid; }
    .splash-inner {
      height: calc(100% - 48px);
      display: grid;
      grid-template-rows: 1fr auto auto;
      align-items: center;
      padding: 20px 32px 44px;
      text-align: center;
    }
    .washer-logo {
      width: 138px;
      height: 138px;
      margin: 0 auto 22px;
      position: relative;
      display: grid;
      place-items: center;
      border-radius: 32px;
      background: rgba(255,255,255,.14);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.22);
    }
    .washer-logo:before {
      content: "";
      width: 72px;
      height: 92px;
      border: 9px solid #fff;
      border-radius: 8px;
      background: linear-gradient(#fff 0 26%, transparent 26%);
    }
    .washer-logo:after {
      content: "";
      position: absolute;
      width: 44px;
      height: 44px;
      border: 7px solid var(--blue);
      border-radius: 50%;
      bottom: 32px;
      left: 47px;
      background: radial-gradient(circle at 62% 58%, transparent 0 15px, var(--blue) 16px 18px, transparent 19px);
    }
    .spark { position: absolute; color: #fff; font-size: 30px; text-shadow: 0 0 14px rgba(255,255,255,.8); }
    .spark.one { top: 28px; right: 26px; }
    .spark.two { bottom: 44px; left: 22px; font-size: 24px; }
    .splash h1 { font-size: 42px; font-weight: 900; margin-bottom: 8px; }
    .splash p { font-size: 17px; opacity: .92; }
    .pill-white {
      justify-self: center;
      width: 200px;
      min-height: 62px;
      border-radius: 999px;
      background: #fff;
      color: var(--blue);
      font-size: 20px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-bottom: 36px;
      box-shadow: 0 18px 34px rgba(5, 54, 119, .18);
    }
    .powered { opacity: .74; font-size: 14px; }

    .login-hero {
      margin: -48px -22px 0;
      min-height: 255px;
      background: var(--blue-dark);
      color: #fff;
      padding: 90px 22px 0;
      text-align: center;
      position: relative;
    }
    .login-hero.customer {
      min-height: 244px;
      background: linear-gradient(180deg, #0874f8, #1288fb);
      border-bottom-left-radius: 50% 16%;
      border-bottom-right-radius: 50% 16%;
    }
    .logo-row { display: flex; align-items: center; justify-content: center; gap: 12px; font-weight: 900; font-size: 34px; }
    .house-mark {
      width: 62px;
      height: 52px;
      position: relative;
      border: 4px solid #fff;
      border-top: 0;
    }
    .house-mark:before {
      content: "";
      position: absolute;
      left: 4px;
      top: -25px;
      width: 43px;
      height: 43px;
      border-left: 4px solid #fff;
      border-top: 4px solid #fff;
      transform: rotate(45deg);
    }
    .rider {
      width: 240px;
      height: 138px;
      margin: 24px auto 0;
      position: relative;
    }
    .rider:before {
      content: "";
      position: absolute;
      left: 24px;
      right: 16px;
      bottom: 26px;
      height: 30px;
      border: 5px solid #fff;
      border-top-width: 8px;
      border-radius: 18px 56px 16px 16px;
      opacity: .96;
    }
    .rider:after {
      content: "";
      position: absolute;
      left: 47px;
      bottom: 0;
      width: 122px;
      height: 48px;
      background:
        radial-gradient(circle at 24px 24px, transparent 0 17px, #fff 18px 21px, transparent 22px),
        radial-gradient(circle at 98px 24px, transparent 0 17px, #fff 18px 21px, transparent 22px);
    }
    .delivery-box {
      position: absolute;
      left: 20px;
      bottom: 58px;
      width: 78px;
      height: 62px;
      border: 4px solid var(--blue);
      color: #fff;
      display: grid;
      place-items: center;
      font-weight: 900;
      background: #0a1736;
      font-size: 14px;
    }
    .login-panel {
      margin: -28px -22px 0;
      background: #fff;
      border-radius: 28px 28px 0 0;
      padding: 52px 26px 28px;
      min-height: 390px;
      position: relative;
      z-index: 2;
    }
    .login-panel.flat {
      margin: 36px 0 0;
      padding: 0;
      min-height: 0;
      border-radius: 0;
    }
    .field {
      border: 1.4px solid #dce2eb;
      border-radius: 8px;
      min-height: 62px;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 0 16px;
      background: #fff;
      color: var(--muted);
      width: 100%;
      resize: none;
    }
    .field input, .field textarea {
      flex: 1;
      border: 0;
      outline: 0;
      min-width: 0;
      color: var(--ink);
      background: transparent;
      font-size: 18px;
    }
    .field textarea { padding: 18px 0; min-height: 96px; }
    .flag { width: 28px; height: 20px; border-radius: 2px; background: #006a4e; position: relative; box-shadow: 0 0 0 1px rgba(0,0,0,.08); }
    .flag:after { content: ""; position: absolute; inset: 5px 9px; background: #f42a41; border-radius: 50%; }
    .divider { width: 1px; align-self: stretch; background: var(--line); margin: 12px 0; }
    .auth-ill {
      width: 116px;
      height: 116px;
      margin: 32px auto 26px;
      position: relative;
      display: grid;
      place-items: center;
      color: var(--blue);
    }
    .phone-line { width: 66px; height: 98px; border: 5px solid var(--blue); border-radius: 13px; position: relative; }
    .phone-line:before { content: ""; position: absolute; top: 5px; left: 21px; width: 18px; height: 4px; background: var(--blue); border-radius: 4px; }
    .code-bubble { position: absolute; right: 0; top: 34px; width: 78px; height: 42px; background: var(--green); color: #fff; border-radius: 6px; display: grid; place-items: center; font-weight: 900; font-size: 24px; box-shadow: 0 10px 20px rgba(19,196,154,.25); }
    #otp .content { padding-left: 24px; padding-right: 24px; }
    #otp .auth-ill { margin-top: 18px; margin-bottom: 24px; }
    #otp .title { font-size: 27px; line-height: 1.18; }
    #otp .subtitle {
      max-width: 310px;
      margin-left: auto;
      margin-right: auto;
      overflow-wrap: anywhere;
    }
    .otp-boxes {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      width: 100%;
      max-width: 304px;
      margin: 28px auto 26px;
    }
    .otp-box {
      width: 100%;
      min-width: 0;
      height: 72px;
      border: 1.5px solid #d9dee8;
      border-radius: 10px;
      display: block;
      text-align: center;
      font-size: 32px;
      line-height: 72px;
      font-weight: 900;
      color: var(--ink);
      background: #fff;
      outline: 0;
      padding: 0;
    }
    .otp-box.active,
    .otp-box:focus { border: 2px solid var(--blue); color: var(--blue); box-shadow: 0 8px 18px rgba(8,116,248,.12); }
    #otp .primary { max-width: 304px; margin-left: auto; margin-right: auto; }

    .banner {
      min-height: 150px;
      border-radius: 10px;
      overflow: hidden;
      margin: 24px 0 14px;
      background: linear-gradient(120deg, #0874f8, #11c8aa);
      color: #fff;
      padding: 24px;
      display: grid;
      grid-template-columns: 1fr 126px;
      gap: 10px;
      align-items: center;
      box-shadow: 0 14px 26px rgba(8, 116, 248, .2);
    }
    .banner h2 { font-size: 25px; font-weight: 900; margin-bottom: 12px; }
    .banner p { font-size: 18px; opacity: .92; margin-bottom: 18px; }
    .mini-outline { width: 125px; min-height: 42px; border: 1.5px solid #fff; border-radius: 8px; color: #fff; font-weight: 800; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .shirt-stack { width: 116px; height: 104px; position: relative; }
    .shirt-stack span {
      position: absolute;
      left: 8px;
      width: 94px;
      height: 26px;
      border-radius: 6px;
      background: #fff;
      box-shadow: 0 6px 10px rgba(3, 67, 125, .2);
      transform: skewY(-8deg);
    }
    .shirt-stack span:nth-child(1) { bottom: 0; }
    .shirt-stack span:nth-child(2) { bottom: 20px; left: 14px; }
    .shirt-stack span:nth-child(3) { bottom: 40px; left: 20px; }
    .shirt-stack span:nth-child(4) { bottom: 60px; left: 26px; height: 34px; }
    .dots { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; }
    .dots span { width: 8px; height: 8px; border-radius: 50%; background: #dce2eb; }
    .dots span.active { background: var(--blue); }
    .service-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .service-card {
      min-height: 104px;
      background: var(--card);
      border-radius: 8px;
      padding: 14px 14px;
      box-shadow: var(--shadow);
      border: 1px solid #f1f3f8;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      text-align: left;
    }
    .service-card .big-icon { color: var(--blue); font-size: 36px; line-height: 1; height: 38px; display: flex; align-items: center; }
    .service-card h3 { font-size: 19px; font-weight: 900; }
    .service-card p { color: var(--muted); font-size: 13px; }
    .current-order, .card {
      background: #fff;
      border: 1px solid #eef1f6;
      border-radius: 8px;
      box-shadow: var(--shadow);
    }
    .current-order {
      margin-top: 12px;
      padding: 14px;
    }
    .home-hero {
      margin: 14px 0 12px;
      padding: 16px;
      border-radius: 14px;
      color: #fff;
      background:
        radial-gradient(circle at 86% 18%, rgba(255,255,255,.28), transparent 24%),
        linear-gradient(135deg, #0874f8, #12c5b1);
      box-shadow: 0 18px 36px rgba(8, 116, 248, .2);
      display: grid;
      grid-template-columns: 1fr 76px;
      gap: 12px;
      align-items: center;
    }
    .home-hero h2 { font-size: 21px; font-weight: 900; line-height: 1.22; margin-bottom: 6px; }
    .home-hero p { color: rgba(255,255,255,.86); font-size: 13px; line-height: 1.4; margin-bottom: 12px; }
    .home-hero-art {
      width: 76px;
      height: 76px;
      border-radius: 20px;
      background: rgba(255,255,255,.18);
      display: grid;
      place-items: center;
      font-size: 42px;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.25);
    }
    .home-stats { display: none; }
    .home-stat {
      min-height: 70px;
      border: 1px solid #edf1f7;
      border-radius: 10px;
      background: #fff;
      box-shadow: 0 8px 20px rgba(9, 22, 50, .06);
      display: grid;
      place-items: center;
      text-align: center;
      padding: 10px 6px;
    }
    .home-stat b { color: var(--blue); font-size: 20px; line-height: 1; }
    .home-stat span { color: var(--muted); font-size: 12px; font-weight: 800; margin-top: 4px; }
    .section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin: 12px 0 10px;
    }
    .section-head h2 { font-size: 21px; font-weight: 900; }
    .order-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .link { color: var(--blue); font-weight: 800; }
    .progress { height: 7px; background: #e1e5ec; border-radius: 8px; overflow: hidden; margin-top: 14px; }
    .progress span { display: block; height: 100%; width: 64%; background: var(--blue); border-radius: inherit; }

    .bottom-nav {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 78px;
      background: rgba(255,255,255,.94);
      backdrop-filter: blur(10px);
      border-top: 1px solid var(--line);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      z-index: 12;
    }
    .nav-item {
      display: grid;
      place-items: center;
      align-content: center;
      gap: 2px;
      color: #687284;
      font-size: 13px;
      font-weight: 800;
      position: relative;
    }
    .nav-item.active { color: var(--blue); }
    .nav-item.active:before { content: ""; position: absolute; top: 0; width: 70%; height: 3px; background: var(--blue); border-radius: 0 0 3px 3px; }
    .nav-item .nav-ico { font-size: 26px; line-height: 1; }

    .chips { display: flex; gap: 12px; overflow: auto; padding: 8px 0 18px; scrollbar-width: none; }
    .chip {
      min-height: 50px;
      padding: 0 21px;
      border-radius: 15px;
      background: #f0f2f6;
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 900;
      white-space: nowrap;
      box-shadow: inset 0 -1px 0 rgba(0,0,0,.04);
      font-size: 18px;
    }
    .chip.active { background: var(--blue); color: #fff; }
    .chip.service { border-radius: 999px; min-height: 42px; font-size: 16px; }
    #order .chips { gap: 8px; padding-bottom: 12px; }
    #order .chip {
      min-height: 42px;
      padding: 0 13px;
      border-radius: 12px;
      font-size: 14px;
      line-height: 1.15;
      flex: 0 0 auto;
    }
    #order .chip.service {
      min-height: 36px;
      font-size: 13px;
      padding: 0 12px;
    }
    #order .service-tabs,
    #order .category-tabs {
      display: grid;
      gap: 8px;
      overflow: visible;
    }
    #order .service-tabs { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    #order .category-tabs { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    #order .service-tabs .chip,
    #order .category-tabs .chip {
      width: 100%;
      min-width: 0;
      justify-content: center;
      text-align: center;
      white-space: normal;
      padding: 0 7px;
      font-size: 12px;
      line-height: 1.12;
    }
    #order .category-tabs .chip {
      min-height: 40px;
      font-size: 13px;
    }
    #order .price-note { font-size: 13px; line-height: 1.55; }
    #order .topbar { min-height: 42px; }
    #order .title { font-size: 26px; line-height: 1.15; }
    .item-list { display: grid; gap: 12px; }
    .item-card[hidden] { display: none; }
    .item-card {
      min-height: 118px;
      border-radius: 8px;
      padding: 16px;
      background: #fff;
      box-shadow: var(--shadow);
      display: grid;
      grid-template-columns: 86px 1fr auto;
      gap: 12px;
      align-items: center;
      border: 1px solid #f0f2f6;
    }
    .line-art { color: var(--blue); font-size: 50px; text-align: center; }
    .item-card h3 { font-size: 23px; font-weight: 900; margin-bottom: 6px; }
    .counter { display: grid; grid-template-columns: 36px 34px 36px; align-items: center; gap: 8px; font-weight: 900; font-size: 25px; }
    .round-btn { width: 36px; height: 36px; border-radius: 50%; display: grid; place-items: center; font-size: 26px; font-weight: 800; background: #eef0f4; color: #667085; }
    .round-btn.plus, .round-btn.minus.active { background: var(--blue); color: #fff; }
    #order .content { padding-bottom: 176px; }
    .order-footer {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      min-height: 118px;
      background: rgba(255,255,255,.96);
      box-shadow: 0 -14px 32px rgba(9,22,50,.11);
      border-radius: 22px 22px 0 0;
      display: grid;
      grid-template-columns: 1fr 82px 170px;
      gap: 12px 16px;
      align-items: center;
      padding: 14px 24px 22px;
      z-index: 12;
    }
    .cart-preview {
      grid-column: 1 / -1;
      min-height: 34px;
      display: flex;
      gap: 8px;
      overflow-x: auto;
      scrollbar-width: none;
      align-items: center;
    }
    .cart-preview::-webkit-scrollbar { display: none; }
    .cart-pill {
      flex: 0 0 auto;
      border-radius: 999px;
      background: #edf5ff;
      color: var(--blue-dark);
      border: 1px solid #dceaff;
      padding: 7px 10px;
      font-size: 12px;
      font-weight: 900;
      white-space: nowrap;
    }
    .cart-pill.dry { background: #f1f3f7; color: #30394d; border-color: #e2e6ee; }
    .cart-pill.all { background: var(--blue); color: #fff; border-color: var(--blue); }
    .see-cart {
