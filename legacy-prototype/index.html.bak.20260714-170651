      "স্যুট": { wash: 250, dry: 350, combo: 270, iron: 25 },
      "টাই": { wash: 40, dry: 40, combo: 45, iron: 8 },
      "বোরকা": { wash: 80, dry: 120, combo: 95, iron: 15 },
      "শাড়ি": { wash: 150, dry: 400, combo: 180, iron: 30 },
      "সালোয়ার, কামিজ, ওড়না": { wash: 120, dry: 180, combo: 140, iron: 25 },
      "ব্লাউজ": { wash: 40, dry: 60, combo: 50, iron: 8 },
      "লেহেঙ্গা / গাউন": { wash: 300, dry: 800, combo: 350, iron: 40 },
      "হিজাব": { wash: 40, dry: 60, combo: 50, iron: 8 },
      "বেডশিট / চাদর": { wash: 60, dry: 60, combo: 70, iron: 15 },
      "বালিশ কভার": { wash: 30, dry: 30, combo: 35, iron: 8 },
      "টাওয়েল": { wash: 80, dry: 80, combo: 85, iron: 8 },
      "পর্দা": { wash: 150, dry: 250, combo: 180, iron: 20 },
      "কম্বল": { wash: 300, dry: 800, combo: 350, iron: 30 },
      "কমফোর্টার": { wash: 200, dry: 650, combo: 250, iron: 30 },
      "নকশী কাঁথা": { wash: 60, dry: 80, combo: 70, iron: 10 },
      "জায়নামাজ": { wash: 0, dry: 0, combo: 0, iron: 0 }
    };

    const toBn = value => String(value).replace(/\d/g, digit => "০১২৩৪৫৬৭৮৯"[digit]);
    const money = value => `৳${toBn(value)}`;

    function getOrderCards() {
      return [...document.querySelectorAll("#order .item-card[data-gender]")];
    }

    function cartKey(service, name) {
      return `${service}::${name}`;
    }

    function selectedItemPrice(name, service = selectedService) {
      const prices = priceMap[name] || {};
      return prices[service] || 0;
    }

    function selectedItemPriceLabel(name) {
      const prices = priceMap[name] || {};
      if (selectedService === "wash") return `Wash ${money(prices.wash || 0)}`;
      return `Dry Clean ${money(prices.dry || 0)}`;
    }

    function cardItemName(card) {
      return card.querySelector("h3").textContent.trim();
    }

    function currentServiceQty(name) {
      return orderCart[cartKey(selectedService, name)]?.qty || 0;
    }

    function updateItemPriceLabels() {
      getOrderCards().forEach(card => {
        const name = cardItemName(card);
        const subtitle = card.querySelector(".subtitle");
        if (subtitle) subtitle.textContent = selectedItemPriceLabel(name);
      });
    }

    function getCart() {
      return Object.values(orderCart)
        .filter(item => item.qty > 0)
        .map(item => ({ ...item, total: item.qty * item.price }));
    }

    function cartSubtotal() {
      return getCart().reduce((sum, item) => sum + item.total, 0);
    }

    function deliveryCharge(subtotal) {
      if (subtotal <= 0) return 0;
      return subtotal >= FREE_DELIVERY_MINIMUM ? 0 : 30;
    }

    function deliveryChargeLabel(subtotal) {
      return deliveryCharge(subtotal) === 0 && subtotal > 0 ? "ফ্রি" : money(deliveryCharge(subtotal));
    }

    function updateCartUI() {
      updateItemPriceLabels();

      const serviceBadge = document.getElementById("selected-service-badge");
      if (serviceBadge) serviceBadge.textContent = `${serviceLabels[selectedService]} ×`;

      getOrderCards().forEach(card => {
        const name = cardItemName(card);
        const qty = currentServiceQty(name);
        const valueEl = card.querySelector(".counter span");
        if (valueEl) valueEl.textContent = toBn(qty);
        const minus = card.querySelector(".round-btn:not(.plus)");
        if (minus) minus.classList.toggle("active", qty > 0);
      });

      const count = getCart().reduce((sum, item) => sum + item.qty, 0);
      const subtotal = cartSubtotal();
      const countEl = document.getElementById("cart-count");
      const totalEl = document.getElementById("cart-total");
      if (countEl) countEl.textContent = `${toBn(count)} পিস`;
      if (totalEl) totalEl.textContent = money(subtotal);
      updateCartPreview();
    }

    function updateCartPreview() {
      const preview = document.getElementById("cart-preview");
      if (!preview) return;
      const cart = getCart();
      preview.innerHTML = cart.length
        ? `${cart.map(item => `<button class="cart-pill ${item.service === "dry" ? "dry" : ""}" data-cart-open="true">${serviceLabels[item.service]}: ${item.name} × ${toBn(item.qty)}</button>`).join("")}<button class="cart-pill all" data-cart-open="true">সব দেখুন</button>`
        : `<span class="muted">কার্টে এখনো কোনো item নেই</span>`;
      updateCartDrawer();
    }

    function openCartDrawer() {
      updateCartDrawer();
      const drawer = document.getElementById("cart-drawer");
      if (drawer) drawer.hidden = false;
    }

    function closeCartDrawer() {
      const drawer = document.getElementById("cart-drawer");
      if (drawer) drawer.hidden = true;
    }

    function updateCartDrawer() {
      const list = document.getElementById("cart-detail-list");
      if (!list) return;
      const cart = getCart();
      list.innerHTML = cart.length
        ? cart.map(item => {
            const key = cartKey(item.service, item.name);
            return `
              <div class="cart-detail-row">
                <div>
                  <h3>${item.name}</h3>
                  <p class="subtitle">${item.serviceLabel} • ${money(item.price)} × ${toBn(item.qty)} = ${money(item.total)}</p>
                </div>
                <div class="cart-detail-actions" data-cart-key="${key}">
                  <button class="round-btn minus active" data-cart-delta="-1">−</button>
                  <span>${toBn(item.qty)}</span>
                  <button class="round-btn plus" data-cart-delta="1">+</button>
                  <button class="remove-cart-item" data-cart-remove="true">বাদ দিন</button>
                </div>
              </div>
            `;
          }).join("")
        : `<div class="summary-card card"><h2>কার্ট খালি</h2><p class="subtitle mt8">Item add করলে এখানে দেখা যাবে।</p></div>`;
    }

    function updateCartItem(name, delta) {
      const key = cartKey(selectedService, name);
      updateCartLine(key, delta);
    }

    function updateCartLine(key, delta) {
      const current = orderCart[key]?.qty || 0;
      const qty = Math.max(current + delta, 0);
      if (!qty) {
        delete orderCart[key];
        return;
      }
      const [service, name] = key.split("::");
      const price = selectedItemPrice(name, service);
      orderCart[key] = {
        name,
        service,
        serviceLabel: serviceLabels[service],
        qty,
        price,
        total: qty * price
      };
    }

    function removeCartLine(key) {
      delete orderCart[key];
    }

    function updateSummary() {
      const cart = getCart();
      const summaryItems = document.getElementById("summary-items");
      const subtotal = cartSubtotal();
      const delivery = deliveryCharge(subtotal);
      const discount = 0;
      const total = Math.max(subtotal + delivery - discount, 0);
      const summaryAddress = document.getElementById("summary-address");
      const summaryAddressInput = document.getElementById("summary-address-input");

      const services = [...new Set(cart.map(item => item.serviceLabel))];
