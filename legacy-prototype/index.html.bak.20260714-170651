      const errorEl = document.getElementById("rider-login-error");
      errorEl.hidden = true;
      if (!username || !password) {
        errorEl.textContent = "ইউজারনেম ও পাসওয়ার্ড দিন।";
        errorEl.hidden = false;
        return;
      }
      try {
        const res = await api("/api/auth/rider-login", { method: "POST", body: JSON.stringify({ username, password }) });
        currentRiderId = res.riderId;
        currentRiderName = res.name;
        showScreen("rider-dashboard");
      } catch (error) {
        errorEl.textContent = "ভুল ইউজারনেম অথবা পাসওয়ার্ড।";
        errorEl.hidden = false;
      }
    }

    async function loadRiderDashboard() {
      setText("rider-name-pill", currentRiderName ? `${currentRiderName} • Online` : "Online");
      if (!currentRiderId) {
        riderTasksCache = [];
      } else {
        try {
          riderTasksCache = await api(`/api/riders/${currentRiderId}/orders`);
        } catch (error) {
          riderTasksCache = [];
        }
      }

      const list = document.getElementById("rider-tasks-list");
      if (!list) return;

      const pickupTasks = riderTasksCache.filter(o => ["pending", "confirmed", "collecting"].includes(statusKeyFromTitle(o.status)));
      const deliveryTasks = riderTasksCache.filter(o => ["packaging", "ready"].includes(statusKeyFromTitle(o.status)));

      if (!pickupTasks.length && !deliveryTasks.length) {
        list.innerHTML = '<p class="subtitle" style="text-align:center;padding:24px 0">এই মুহূর্তে কোনো টাস্ক নেই।</p>';
        return;
      }

      const pickupHtml = pickupTasks.map(order => {
        const itemCount = (order.items || []).reduce((sum, i) => sum + (i.qty || 1), 0);
        return `
          <div class="rider-task card mt16">
            <div class="queue-top"><div><h2>Pickup #${order.id}</h2><p class="subtitle">${order.customerName} • ${order.address}</p></div><span class="tiny-pill orange">${statusKeyFromTitle(order.status) === "collecting" ? "Collecting" : "Pending"}</span></div>
            <p>${toBn(itemCount)} পিস • ${order.service} • ${order.payment} ${money(order.total)}</p>
            <div class="action-row"><a class="small-btn soft" href="tel:${order.phone}">Call Customer</a><button class="small-btn" data-open-rider-task="${order.id}">Start Pickup</button></div>
          </div>`;
      }).join("");

      const deliveryHtml = deliveryTasks.map(order => {
        const itemCount = (order.items || []).reduce((sum, i) => sum + (i.qty || 1), 0);
        return `
          <div class="rider-task card mt16">
            <div class="queue-top"><div><h2>Delivery #${order.id}</h2><p class="subtitle">${order.customerName} • ${order.address}</p></div><span class="tiny-pill green">Ready</span></div>
            <p>${toBn(itemCount)} পিস • ${order.payment} • ${money(order.total)}</p>
            <div class="action-row"><button class="small-btn soft" data-rider-navigate="${order.address}">Navigate</button><button class="small-btn" data-rider-deliver="${order.id}">Deliver</button></div>
          </div>`;
      }).join("");

      list.innerHTML = pickupHtml + deliveryHtml;
    }

    function loadRiderTaskDetail() {
      const order = riderTasksCache.find(o => o.id === currentRiderTaskOrderId);
      if (!order) {
        setText("rider-task-id", "#—");
        setText("rider-task-customer", "কোনো টাস্ক নির্বাচিত নেই");
        return;
      }
      setText("rider-task-id", `#${order.id}`);
      setText("rider-task-customer", `${order.customerName} • ${order.phone}`);
      setText("rider-task-address", order.address);
      const itemCount = (order.items || []).reduce((sum, i) => sum + (i.qty || 1), 0);
      setText("rider-task-items", `${toBn(itemCount)} পিস`);
      setText("rider-task-collect", `${order.payment} ${money(order.total)}`);
      const call = document.getElementById("rider-task-call");
      if (call) call.href = `tel:${order.phone}`;
    }

    async function riderMarkCollected() {
      if (!currentRiderTaskOrderId) return;
      try {
        await api(`/api/orders/${currentRiderTaskOrderId}/status`, {
          method: "PATCH",
          body: JSON.stringify({ status: statusTitleFromKey("collected") })
        });
        showScreen("rider-dashboard");
      } catch (error) {
        alert("Status update ব্যর্থ হয়েছে। আবার চেষ্টা করুন।");
      }
    }

    async function riderMarkDelivered(orderId) {
      if (!confirm("এই অর্ডারটি delivered হিসেবে mark করবেন?")) return;
      try {
        await api(`/api/orders/${orderId}/status`, {
          method: "PATCH",
          body: JSON.stringify({ status: statusTitleFromKey("delivered") })
        });
        loadRiderDashboard();
      } catch (error) {
        alert("Status update ব্যর্থ হয়েছে। আবার চেষ্টা করুন।");
      }
    }

    function showScreen(id) {
      if (id === "summary") updateSummary();
      if (id === "orders") loadCustomerOrders();
      if (id === "tracking") renderTrackingStatus();
      if (id === "admin-dashboard") loadAdminDashboard();
      if (id === "admin-order") loadAdminOrderDetail();
      if (id === "admin-pricing") loadAdminPricing();
      if (id === "admin-customers") loadAdminCustomers();
      if (id === "admin-riders") loadAdminRiders();
      if (id === "admin-reports") loadAdminReports();
      if (id === "rider-dashboard") loadRiderDashboard();
      if (id === "rider-task") loadRiderTaskDetail();
      screens.forEach(screen => screen.classList.toggle("active", screen.id === id));
      const active = document.getElementById(id);
      if (active) {
        const scrollable = active.querySelector(".content");
        if (scrollable) scrollable.scrollTop = 0;
      }
    }

    function filterOrderItems(category) {
      document.querySelectorAll("[data-category]").forEach(button => {
        button.classList.toggle("active", button.dataset.category === category);
      });
      document.querySelectorAll("#order .item-card[data-gender]").forEach(card => {
        const visible = category === "all" || card.dataset.gender === category;
        card.hidden = !visible;
      });
    }

    function setActiveOtpBox(activeInput) {
      document.querySelectorAll("#otp .otp-box").forEach(input => {
        input.classList.toggle("active", input === activeInput);
      });
    }

    function openSummaryAddressEdit() {
      const edit = document.getElementById("summary-address-edit");
      const input = document.getElementById("summary-address-input");
      if (!edit || !input) return;
      input.value = userProfile.address || "";
      edit.hidden = false;
      input.focus();
    }

    function saveSummaryAddress() {
      const edit = document.getElementById("summary-address-edit");
      const input = document.getElementById("summary-address-input");
      if (!input) return;
      const address = input.value.trim();
      if (!address) return alert("ডেলিভারি ঠিকানা লিখুন।");
      userProfile.address = address;
      const summaryAddress = document.getElementById("summary-address");
      if (summaryAddress) summaryAddress.textContent = userProfile.address;
      if (edit) edit.hidden = true;
      syncUserText();
    }

    let currentChatOrderId = null;
    const chatRoleNames = { customer: "Customer", admin: "Admin", rider: "Rider" };

    function resolveChatOrderId(role) {
      if (role === "admin") return currentAdminOrderId;
      if (role === "rider") return currentRiderTaskOrderId;
      return lastOrderId;
    }

    function resolveChatOrderPhone(orderId) {
      const fromAdmin = (typeof adminOrdersCache !== "undefined" ? adminOrdersCache : []).find(o => o.id === orderId);
      if (fromAdmin) return fromAdmin.phone;
      const fromRider = (typeof riderTasksCache !== "undefined" ? riderTasksCache : []).find(o => o.id === orderId);
      if (fromRider) return fromRider.phone;
      return "";
    }

    async function openChat(role = "customer") {
      chatRole = role;
      currentChatOrderId = resolveChatOrderId(role);
      const title = document.getElementById("chat-title");
      if (title) title.textContent = role === "admin" ? "Admin Order Chat" : role === "rider" ? "Rider Order Chat" : "Order Chat";
      const subtitle = document.getElementById("chat-subtitle");
      if (subtitle) subtitle.textContent = currentChatOrderId ? `Order #${currentChatOrderId}` : "No order selected";

      const waBtn = document.getElementById("chat-whatsapp");
      if (waBtn) {
        const phone = role !== "customer" ? resolveChatOrderPhone(currentChatOrderId) : "";
        const digits = (phone || "").replace(/\D/g, "");
        waBtn.href = digits ? `https://wa.me/${digits}` : "#";
        waBtn.hidden = !digits;
      }

      const panel = document.getElementById("chat-panel");
      if (panel) panel.hidden = false;
      await loadChatMessages();
    }

    function closeChat() {
      const panel = document.getElementById("chat-panel");
      if (panel) panel.hidden = true;
    }

    async function loadChatMessages() {
      const box = document.getElementById("chat-messages");
      if (!box) return;
      if (!currentChatOrderId) {
        box.innerHTML = '<p class="subtitle" style="text-align:center;padding:16px">কোনো অর্ডার নির্বাচিত নেই।</p>';
        return;
      }
      let messages = [];
      try {
        messages = await api(`/api/orders/${currentChatOrderId}/messages`);
      } catch (error) {
        messages = [];
      }
      if (!messages.length) {
        box.innerHTML = '<p class="subtitle" style="text-align:center;padding:16px">এখনো কোনো মেসেজ নেই। প্রথম মেসেজ পাঠান।</p>';
        return;
      }
      box.innerHTML = messages.map(message => {
        const mine = message.sender === chatRole;
        const time = new Date(message.createdAt).toLocaleTimeString([], { hour: "numeric", minute: "2-digit" });
        return `<div class="chat-bubble ${mine ? "me" : ""}"><strong>${chatRoleNames[message.sender] || message.sender}</strong><br>${message.text}<small>${time}</small></div>`;
      }).join("");
      box.scrollTop = box.scrollHeight;
    }

    async function sendChatMessage() {
      const input = document.getElementById("chat-input");
      if (!input || !currentChatOrderId) return;
      const text = input.value.trim();
      if (!text) return;
      input.value = "";
      try {
        await api(`/api/orders/${currentChatOrderId}/messages`, {
          method: "POST",
          body: JSON.stringify({ text, sender: chatRole })
        });
        await loadChatMessages();
      } catch (error) {
        alert("মেসেজ পাঠানো যায়নি। আবার চেষ্টা করুন।");
      }
    }

    document.querySelectorAll("#otp .otp-box").forEach((input, index, inputs) => {
      input.addEventListener("focus", () => setActiveOtpBox(input));
      input.addEventListener("input", () => {
        input.value = input.value.replace(/\D/g, "").slice(-1);
        setActiveOtpBox(input);
        if (input.value && inputs[index + 1]) inputs[index + 1].focus();
      });
      input.addEventListener("keydown", event => {
        if (event.key === "Backspace" && !input.value && inputs[index - 1]) {
          inputs[index - 1].focus();
        }
      });
    });

    document.getElementById("chat-input")?.addEventListener("keydown", event => {
      if (event.key === "Enter") {
        event.preventDefault();
        sendChatMessage();
      }
    });

    document.addEventListener("click", event => {
      const chatTrigger = event.target.closest("[data-chat-open]");
      if (chatTrigger) {
        openChat(chatTrigger.dataset.chatOpen || "customer");
        return;
      }

      if (event.target.closest("#chat-close")) {
        closeChat();
        return;
      }

      const chatPanel = event.target.closest("#chat-panel");
      if (chatPanel && event.target === chatPanel) {
        closeChat();
        return;
      }

      if (event.target.closest("#chat-send")) {
        sendChatMessage();
        return;
      }

      const adminTabTrigger = event.target.closest("[data-admin-tab]");
      if (adminTabTrigger) {
        adminActiveTab = adminTabTrigger.dataset.adminTab;
        document.querySelectorAll("[data-admin-tab]").forEach(btn => btn.classList.toggle("active", btn === adminTabTrigger));
        renderAdminOrderList();
        return;
      }

      const openOrderTrigger = event.target.closest("[data-open-admin-order]");
      if (openOrderTrigger) {
        openAdminOrder(openOrderTrigger.dataset.openAdminOrder);
        return;
      }

      const adminAssignTrigger = event.target.closest("[data-admin-assign-rider]");
      if (adminAssignTrigger) {
        adminAssignRider(adminAssignTrigger.dataset.adminAssignRider);
        return;
      }

      const adminOrderStatusTrigger = event.target.closest("[data-admin-order-status]");
      if (adminOrderStatusTrigger) {
        document.querySelectorAll("[data-admin-order-status]").forEach(btn => btn.classList.toggle("active", btn === adminOrderStatusTrigger));
        return;
      }

      if (event.target.closest("#admin-order-update-btn")) {
        adminUpdateOrderStatus();
        return;
      }

      const priceRowTrigger = event.target.closest(".price-table-row[data-price-id]");
      if (priceRowTrigger) {
        openAdminPriceEdit(priceRowTrigger.dataset.priceId);
        return;
      }

      if (event.target.closest("#admin-price-add-btn")) {
        openAdminPriceEdit(null);
        return;
      }

      if (event.target.closest("#admin-price-save-btn")) {
        saveAdminPrice();
        return;
      }

      if (event.target.closest("#rider-login-btn")) {
        riderLogin();
        return;
      }

      const openRiderTaskTrigger = event.target.closest("[data-open-rider-task]");
      if (openRiderTaskTrigger) {
        currentRiderTaskOrderId = openRiderTaskTrigger.dataset.openRiderTask;
        showScreen("rider-task");
        return;
      }

      const navigateTrigger = event.target.closest("[data-rider-navigate]");
      if (navigateTrigger) {
        const address = navigateTrigger.dataset.riderNavigate || "";
        window.open(`https://www.google.com/maps/search/${encodeURIComponent(address)}`, "_blank");
        return;
      }

      const deliverTrigger = event.target.closest("[data-rider-deliver]");
      if (deliverTrigger) {
        riderMarkDelivered(deliverTrigger.dataset.riderDeliver);
        return;
      }

      if (event.target.closest("#rider-task-action-btn")) {
        riderMarkCollected();
        return;
      }

      if (event.target.closest("[data-cart-open]") || event.target.closest("#cart-count") || event.target.closest("#cart-total")) {
        openCartDrawer();
        return;
      }

      if (event.target.closest("#cart-close")) {
        closeCartDrawer();
        return;
      }

      const drawer = event.target.closest("#cart-drawer");
      if (drawer && event.target === drawer) {
        closeCartDrawer();
        return;
      }

      const cartDeltaButton = event.target.closest("[data-cart-delta]");
      if (cartDeltaButton) {
        const actions = cartDeltaButton.closest("[data-cart-key]");
        updateCartLine(actions.dataset.cartKey, Number(cartDeltaButton.dataset.cartDelta));
        updateCartUI();
        return;
      }

      const cartRemoveButton = event.target.closest("[data-cart-remove]");
      if (cartRemoveButton) {
        const actions = cartRemoveButton.closest("[data-cart-key]");
        removeCartLine(actions.dataset.cartKey);
        updateCartUI();
        return;
      }

      const serviceTrigger = event.target.closest("[data-service]");
      if (serviceTrigger) {
        selectedService = serviceTrigger.dataset.service;
        document.querySelectorAll("[data-service]").forEach(button => {
          button.classList.toggle("active", button === serviceTrigger);
        });
        updateCartUI();
        return;
      }

      const areaOption = event.target.closest(".area-option");
      if (areaOption) {
        document.querySelectorAll(".area-option").forEach(button => button.classList.toggle("active", button === areaOption));
        document.getElementById("area-input").value = areaOption.textContent.trim();
        document.getElementById("area-list").hidden = true;
        return;
      }

      if (event.target.closest("#area-picker")) {
        const areaList = document.getElementById("area-list");
        areaList.hidden = !areaList.hidden;
        return;
      }

      if (event.target.closest("#send-otp")) {
        sendOtp();
        return;
      }

      if (event.target.closest("#verify-otp")) {
        verifyOtp();
        return;
      }

      if (event.target.closest("#save-profile")) {
        saveProfile();
        return;
      }

      if (event.target.closest("#logout-button")) {
        userProfile.phone = "";
        userProfile.name = "";
        userProfile.area = "";
        userProfile.address = "";
        syncUserText();
        showScreen("splash");
        return;
      }

      if (event.target.closest("#summary-address-change")) {
        openSummaryAddressEdit();
        return;
      }

      if (event.target.closest("#summary-address-save")) {
        saveSummaryAddress();
        return;
      }

      const categoryTrigger = event.target.closest("[data-category]");
      if (categoryTrigger) {
        filterOrderItems(categoryTrigger.dataset.category);
        return;
      }

      const counterButton = event.target.closest(".round-btn");
      if (counterButton) {
        const card = counterButton.closest(".item-card");
        const name = cardItemName(card);
        const delta = counterButton.classList.contains("plus") ? 1 : -1;
        updateCartItem(name, delta);
        updateCartUI();
        return;
      }

      if (event.target.closest("#confirm-order")) {
        confirmOrder();
        return;
      }

      const trigger = event.target.closest("[data-screen]");
      if (!trigger) return;
      const orderCard = event.target.closest("[data-order-id]");
      if (orderCard) {
        lastOrderId = orderCard.dataset.orderId;
        const trackingId = document.getElementById("tracking-order-id");
        if (trackingId) trackingId.textContent = `#${lastOrderId}`;
      }
      showScreen(trigger.dataset.screen);
    });

    document.addEventListener("keydown", event => {
      if (event.key === "Escape") showScreen("home");
    });

    document.addEventListener("input", event => {
      if (event.target.id === "admin-customer-search") {
        const q = event.target.value.trim().toLowerCase();
        const filtered = !q ? adminCustomersCache : adminCustomersCache.filter(c =>
          (c.name || "").toLowerCase().includes(q) || (c.phone || "").includes(q)
        );
        renderAdminCustomerList(filtered);
      }
    });

    updateCartUI();
    syncRiderText();
    renderTrackingStatus();
    loadBackendStatus();
  </script>
</body>
</html>

