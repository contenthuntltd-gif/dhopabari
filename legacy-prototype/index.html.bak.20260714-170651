      const total = Math.max(subtotal + delivery - discount, 0);
      return {
        customerName: userProfile.name || "গ্রাহক",
        phone: userProfile.phone || "০১৭XXXXXXXX",
        address: userProfile.address || "কলাতলী, কক্সবাজার",
